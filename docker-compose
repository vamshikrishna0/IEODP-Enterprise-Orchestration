version: "3.9"

services:

  app:
    build: .
    container_name: ieodp_app
    ports:
      - "8000:8000"
    depends_on:
      - mysql
      - redis
    environment:
      - DATABASE_URL=mysql+pymysql://root:password@mysql:3306/ieodp
      - REDIS_URL=redis://redis:6379/0

  mysql:
    image: mysql:8.0
    container_name: ieodp_mysql
    restart: always
    environment:
      MYSQL_ROOT_PASSWORD: password
      MYSQL_DATABASE: ieodp
    ports:
      - "3306:3306"
    volumes:
      - mysql_data:/var/lib/mysql

  redis:
    image: redis:7
    container_name: ieodp_redis
    ports:
      - "6379:6379"

  celery:
    build: .
    container_name: ieodp_celery
    command: celery -A app.worker worker --loglevel=info
    depends_on:
      - redis
      - mysql

volumes:
  mysql_data:
